# vmware_licenses_exporter — sample environment file.
#
# Copy to `.env` (gitignored) and fill in real values:
#     cp .env.example .env
#
# `config.yaml` is the source of truth for which of these are actually consumed:
# every `${ENV}` it references must be set, or the exporter fails fast at load
# with `config references unset environment variable "..."`. A `.env` file is a
# local convenience for that `${ENV}` expansion — never the source of truth.
# For file-based secrets, use `passwordFile` in config.yaml instead of VC_PASSWORD.

# --- vCenter credentials (referenced by config.yaml's ${VC_*} placeholders) ---
VC_HOST=https://vcenter.example.com
VC_USERNAME=svc-ro
VC_PASSWORD=

# --- Demo stack (docker-compose only; both have built-in defaults) ---
# Grafana admin password for `docker compose up` (defaults to `admin`).
GRAFANA_ADMIN_PASSWORD=admin
# Published image tag for docker-compose.ghcr.yml (defaults to `latest`).
VMWARE_LICENSES_EXPORTER_TAG=latest
