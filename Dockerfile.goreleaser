# Release image: copies the prebuilt GoReleaser binary (no builder stage, so there is
# no builder to COPY a CA bundle from). distroless/static:nonroot already bundles
# ca-certificates and runs as a non-root user (65532:65532) — no `apk add` needed.
FROM gcr.io/distroless/static:nonroot
COPY vmware_licenses_exporter /usr/local/bin/vmware_licenses_exporter
COPY config.yaml /etc/vmware_licenses_exporter/config.yaml
EXPOSE 9106
ENTRYPOINT ["/usr/local/bin/vmware_licenses_exporter"]
CMD ["--config", "/etc/vmware_licenses_exporter/config.yaml"]
