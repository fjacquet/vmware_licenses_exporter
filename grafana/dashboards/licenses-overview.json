{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "title": "Enterprise Licenses — Overview",
  "uid": "licenses-overview",
  "tags": [
    "licenses",
    "vmware_licenses_exporter"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "vendor",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(license_up, vendor)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(license_up{vendor=~\"$vendor\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "product",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(license_seats_total{vendor=~\"$vendor\"}, product)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Seat utilization %",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "orientation": "horizontal"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * license_seats_used{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"} / license_seats_total{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"}",
          "legendFormat": "{{vendor}}/{{product}} ({{instance}})"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Over-allocated licenses",
      "description": "Count of products whose used seats exceed purchased capacity (used > total). \"None ✓\" (green) = nothing over-allocated; a red number is the count of breaching products.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "None ✓",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(license_seats_used{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"} > license_seats_total{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"}) or vector(0)",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Seats free",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "license_seats_total{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"} - license_seats_used{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"}",
          "legendFormat": "{{vendor}}/{{product}} ({{instance}})"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Soonest expiry",
      "description": "Days until the earliest-expiring license key (min across the current filters). \"No expiry ✓\" (green) = no expiry is emitted at all, i.e. every matching key is perpetual (the exporter omits expiration for perpetual keys). Red < 30d, yellow < 90d.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 100000000,
                "to": 10000000000,
                "result": {
                  "text": "No expiry ✓",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 30
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min((license_expiration_timestamp_seconds{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"} - time()) / 86400) or vector(1000000000)",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Expiring < 30d",
      "description": "Count of license keys whose expiry is within 30 days (or already past). \"None ✓\" (green) = nothing expiring soon; a red number is the count. Perpetual keys emit no expiry and never count here.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "None ✓",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "center"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(license_expiration_timestamp_seconds{vendor=~\"$vendor\",product=~\"$product\",instance=~\"$instance\"} - time() < 30*86400) or vector(0)",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Collector health",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Down",
                  "color": "red"
                },
                "1": {
                  "text": "Up",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "license_up{vendor=~\"$vendor\",instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Last refresh age (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 7200
              },
              {
                "color": "red",
                "value": 14400
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - license_collector_last_success_timestamp_seconds{vendor=~\"$vendor\",instance=~\"$instance\"}",
          "legendFormat": "{{vendor}} ({{instance}})"
        }
      ]
    }
  ],
  "description": "Seat utilization, over-allocation, expiration, and collector health across all license vendors."
}
